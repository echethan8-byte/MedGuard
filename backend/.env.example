# ── MedGuard Environment Configuration ────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Django
SECRET_KEY=your-strong-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — use SQLite for quick local dev
USE_SQLITE=True
# PostgreSQL (set USE_SQLITE=False to use)
DB_NAME=medguard_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# LLM API Keys — add at least one
LLM_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# RAG
RAG_TOP_K_RETRIEVE=20
RAG_TOP_K_RERANK=8
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# CORS (frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
